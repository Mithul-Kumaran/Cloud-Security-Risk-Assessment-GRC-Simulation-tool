</div>

<!-- SIDEBAR -->
<aside class="sidebar">
  <div class="sidebar-section">
    <div class="sidebar-section-label">Assessment Workflow</div>
    <div class="nav-item active" onclick="navigate(0, this)">
      <span class="nav-icon">▦</span> Asset Inventory
    </div>
    <div class="nav-item" onclick="navigate(1, this)">
